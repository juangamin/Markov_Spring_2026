Cell[BoxData[
 RowBox[{
  RowBox[{"tie2", "[", "t_", "]"}], ":=", 
  RowBox[{"If", "[", 
   RowBox[{
    RowBox[{"t", "<", "60"}], ",", 
    RowBox[{
     RowBox[{"Exp", "[", 
      RowBox[{
       RowBox[{"-", 
        FractionBox["7", "2"]}], 
       RowBox[{"(", 
        RowBox[{"1", "-", 
         FractionBox["t", "90"]}], ")"}]}], "]"}], " ", 
     RowBox[{"NSum", "[", 
      RowBox[{
       FractionBox[
        RowBox[{
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"2", "-", 
            FractionBox[
             RowBox[{"2", "t"}], "90"]}], ")"}], "k"], 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{
            FractionBox["3", "2"], "-", 
            FractionBox["t", "60"]}], ")"}], "k"]}], 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"k", "!"}], ")"}], "2"]], ",", 
       RowBox[{"{", 
