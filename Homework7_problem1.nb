Notebook[{
Cell["Probability that A wins", "Text",
 CellFrame->{{0, 0}, {0, 0}},
 CellChangeTimes->{{3.9839859560948544`*^9, 3.983985965921836*^9}},
 FontColor->RGBColor[
  1, 0, 0],ExpressionUUID->"000eeb90-5671-4e61-92b2-ceffa1af94e1"],

Cell[BoxData[
 RowBox[{"NSum", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"Exp", "[", 
     RowBox[{"-", "2"}], "]"}], 
    FractionBox[
     SuperscriptBox["2", "j"], 
     RowBox[{"j", "!"}]], 
    RowBox[{"Exp", "[", 
     RowBox[{
      RowBox[{"-", "3"}], "/", "2"}], "]"}], 
    FractionBox[
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"3", "/", "2"}], ")"}], "k"], 
     RowBox[{"k", "!"}]]}], ",", 
   RowBox[{"{", 
    RowBox[{"k", ",", "0", ",", "Infinity"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"j", ",", 
     RowBox[{"k", "+", "1"}], ",", "Infinity"}], "}"}]}], "]"}]], "Input",Expr\
essionUUID->"5a2c7e95-a435-4e68-b72e-31d4ac5417bb"],

Cell[TextData[StyleBox["Probability of a tie as a function of t",
 FontColor->RGBColor[1, 0, 0]]], "Text",
 CellChangeTimes->{{3.9839859560948544`*^9, 
  3.983985981266891*^9}},ExpressionUUID->"c84e84d9-ddd4-46a3-b86a-\
50c4c4114a25"],

Cell[BoxData[
 RowBox[{
  RowBox[{"tie", "[", "t_", "]"}], ":=", 
  RowBox[{
   RowBox[{"Exp", "[", 
    RowBox[{
     RowBox[{"-", 
      FractionBox["7", "2"]}], 
     RowBox[{"(", 
      RowBox[{"1", "-", 
       FractionBox["t", "90"]}], ")"}]}], "]"}], " ", 
   RowBox[{"NSum", "[", 
    RowBox[{
     FractionBox[
      RowBox[{
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"2", "-", 
          FractionBox[
           RowBox[{"2", "t"}], "90"]}], ")"}], "k"], 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{
          FractionBox["3", "2"], "-", 
          FractionBox["t", "60"]}], ")"}], "k"]}], 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"k", "!"}], ")"}], "2"]], ",", 
     RowBox[{"{", 
      RowBox[{"k", ",", "0", ",", "10"}], "}"}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.983986020761177*^9, 3.983986116269409*^9}, {
  3.983986156229147*^9, 3.9839861679449873`*^9}},
 CellLabel->
  "In[127]:=",ExpressionUUID->"cfb52620-1202-49eb-89fd-48cb8d4e04ee"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"tie", "[", "0", "]"}]], "Input",
